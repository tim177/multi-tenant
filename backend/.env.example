# ---- Supabase Postgres connection ----
# Get these from Supabase: Project -> Connect -> ORMs (Prisma).
# DATABASE_URL = "Transaction pooler" string (host ...pooler.supabase.com, port 6543) + ?pgbouncer=true
# DIRECT_URL   = "Direct connection"  string (port 5432) used only for migrations
DATABASE_URL="postgresql://postgres.xxxx:[YOUR-PASSWORD]@aws-0-region.pooler.supabase.com:6543/postgres?pgbouncer=true"
DIRECT_URL="postgresql://postgres.xxxx:[YOUR-PASSWORD]@aws-0-region.pooler.supabase.com:5432/postgres"

# ---- Auth ----
JWT_SECRET="change-me-to-a-long-random-string"
JWT_EXPIRES_IN="7d"

# ---- Super Admin (static credentials, NOT stored in the DB) ----
SUPER_ADMIN_EMAIL="superadmin@host.com"
SUPER_ADMIN_PASSWORD="super-secret-password"

# ---- Server ----
PORT=4000
